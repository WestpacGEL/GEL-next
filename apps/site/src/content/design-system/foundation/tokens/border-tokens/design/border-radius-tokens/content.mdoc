r", restricted: true, new: false}, {tokenName: "rounded-5xl", description: "This radius is restricted for very large promos and containers in the Public site.", fillColour: "surface-info-faint", strokeColour: "border-info-mild", circleType: "border", restricted: true, new: false}, {tokenName: "rounded-full", description: "For pill shaped UI components - Badges, Switches, Progress bars etc.", fillColour: "surface-info-faint", strokeColour: "border-info-mild", circleType: "border", restricted: false, new: false}] /%}
